---
import fs from 'node:fs';
import path from 'node:path';

const siteUrl = 'https://healthstrat.pages.dev';

const pageMeta = {
  'index.html': {
    title: 'HealthStrat - Healthcare Strategy & Transformation Consultancy',
    description:
      'HealthStrat helps healthcare leaders strengthen strategy, clinical governance, workforce capability, education, and transformation across Singapore and regional health systems.',
  },
  'about.html': {
    title: 'About HealthStrat | Healthcare Transformation Leadership',
    description:
      'Learn about HealthStrat and Dr Prema K., a senior healthcare transformation leader supporting hospitals, health systems, community care, education, and workforce development.',
  },
  'expertise.html': {
    title: 'Healthcare Consulting Expertise | HealthStrat',
    description:
      'Explore HealthStrat expertise in healthcare strategy, clinical governance, nursing workforce development, innovation, education, operational readiness, and community care.',
  },
  'contact.html': {
    title: 'Contact HealthStrat | Healthcare Strategy Consultancy',
    description:
      'Contact HealthStrat to discuss healthcare strategy, clinical leadership, transformation, training, workforce development, and regional healthcare advisory support.',
  },
};

export function getStaticPaths() {
  const htmlFiles = fs
    .readdirSync(process.cwd())
    .filter((file) => file.endsWith('.html'))
    .sort();

  return htmlFiles.map((file) => ({
    params: {
      slug: file === 'index.html' ? undefined : file.replace(/\.html$/, ''),
    },
    props: {
      file,
    },
  }));
}

const { file } = Astro.props;
const pagePath = path.join(process.cwd(), file);
const manifestPath = path.join(process.cwd(), 'public', 'assets', 'image-manifest.json');
const imageManifest = fs.existsSync(manifestPath)
  ? JSON.parse(fs.readFileSync(manifestPath, 'utf-8'))
  : {};
const meta = pageMeta[file] || {
  title: 'HealthStrat | Healthcare Strategy & Transformation Consultancy',
  description:
    'HealthStrat supports healthcare organisations with strategy, clinical governance, workforce development, education, innovation, and transformation advisory.',
};
const pathname = file === 'index.html' ? '/' : `/${file.replace(/\.html$/, '')}/`;
const canonicalUrl = `${siteUrl}${pathname}`;
const ctaButtonPages = new Set([
  'about.html',
  'expertise.html',
  'health-care-strategy-transformation.html',
  'clinical-governance-quality.html',
  'nursing-workforce-development.html',
  'innovation-design-thinking.html',
  'education-training.html',
]);
const serviceCtaButtonPages = new Set([
  'health-care-strategy-transformation.html',
  'clinical-governance-quality.html',
  'nursing-workforce-development.html',
  'innovation-design-thinking.html',
  'education-training.html',
]);
const expertiseCtaButtonPages = new Set(['expertise.html']);

const sharedCtaButtons = `          <div class="cs_healthstrat_cta_actions">
            <a href="contact.html" class="cs_healthstrat_final_cta_btn cs_healthstrat_final_cta_primary cs_w_100_sm" aria-label="Book a Strategy Discussion">
              <i class="fa-regular fa-calendar-days cs_healthstrat_final_cta_icon" aria-hidden="true"></i>
              <span>Book a Strategy Discussion</span>
              <i class="fa-solid fa-arrow-right cs_healthstrat_final_cta_arrow" aria-hidden="true"></i>
            </a>
            <a href="https://wa.me/6591176220" class="cs_healthstrat_final_cta_btn cs_healthstrat_final_cta_whatsapp cs_w_100_sm" aria-label="WhatsApp HealthStrat">
              <i class="fa-brands fa-whatsapp cs_healthstrat_final_cta_icon" aria-hidden="true"></i>
              <span>WhatsApp Us</span>
            </a>
          </div>`;

const expertiseCtaButtons = `          <div class="cs_healthstrat_cta_actions cs_healthstrat_expertise_cta_actions">
            <a href="contact.html" class="cs_healthstrat_expertise_cta_btn cs_healthstrat_expertise_cta_primary" aria-label="Book a Strategy Discussion">
              <i class="fa-regular fa-calendar-days cs_healthstrat_expertise_cta_icon" aria-hidden="true"></i>
              <span>Book a Strategy Discussion</span>
              <i class="fa-solid fa-arrow-right cs_healthstrat_expertise_cta_arrow" aria-hidden="true"></i>
            </a>
            <a href="https://wa.me/6591176220" class="cs_healthstrat_expertise_cta_btn cs_healthstrat_expertise_cta_secondary" aria-label="WhatsApp HealthStrat">
              <i class="fa-brands fa-whatsapp cs_healthstrat_expertise_cta_icon" aria-hidden="true"></i>
              <span>WhatsApp Us</span>
            </a>
          </div>`;

const sharedCtaButtonStyles = `    <style id="healthstrat-shared-cta-buttons">
      .cs_healthstrat_cta_actions {
        display: flex;
        align-items: center;
        justify-content: center;
        flex-wrap: wrap;
        gap: 14px;
      }
      .cs_healthstrat_final_cta_btn {
        min-height: 46px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        border-radius: 999px;
        color: #fff;
        font-size: 23px;
        font-weight: 700;
        line-height: 1.2;
        box-shadow: none;
      }
      .cs_healthstrat_final_cta_btn:hover {
        color: #fff;
        transform: translateY(-2px);
      }
      .cs_healthstrat_final_cta_primary {
        min-width: 282px;
        padding: 0 0 0 22px;
        background: linear-gradient(135deg, #003b71 0%, #005090 100%);
      }
      .cs_healthstrat_final_cta_primary:hover {
        background: linear-gradient(135deg, #002f5d 0%, #00477f 100%);
      }
      .cs_healthstrat_final_cta_whatsapp {
        min-width: 150px;
        padding: 0 20px;
        background: linear-gradient(135deg, #2f9f44 0%, #60a030 100%);
        box-shadow: none;
      }
      .cs_healthstrat_final_cta_whatsapp:hover {
        background: linear-gradient(135deg, #238936 0%, #4f9228 100%);
      }
      .cs_healthstrat_final_cta_icon {
        font-size: 28px;
        line-height: 1;
      }
      .cs_healthstrat_final_cta_arrow {
        min-height: 46px;
        width: 46px;
        margin-left: 2px;
        border-left: 1px solid rgba(255, 255, 255, 0.18);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 25px;
      }
      @media (max-width: 575px) {
        .cs_healthstrat_cta_actions .cs_btn,
        .cs_healthstrat_final_cta_btn {
          width: 100%;
        }
        .cs_healthstrat_final_cta_btn {
          min-width: 0;
          min-height: 60px;
          font-size: 25px;
          gap: 12px;
        }
        .cs_healthstrat_final_cta_primary {
          padding-left: 24px;
        }
        .cs_healthstrat_final_cta_arrow {
          min-height: 60px;
          width: 62px;
          margin-left: auto;
        }
      }
    </style>`;

const serviceCtaButtonStyles = `    <style id="healthstrat-service-cta-buttons">
      .cs_healthstrat_service_cta_actions {
        flex-direction: column;
        align-items: center;
        justify-content: center;
        justify-self: end;
        align-self: center;
        min-width: 320px;
        transform: translateX(-22px);
      }
      .cs_healthstrat_service_cta_actions .cs_healthstrat_final_cta_primary {
        width: 100%;
        min-width: 0;
      }
      .cs_healthstrat_service_cta_actions .cs_healthstrat_final_cta_whatsapp {
        width: auto;
        min-width: 0;
        padding-left: 24px;
        padding-right: 24px;
      }
      .cs_healthstrat_service_cta_actions .cs_healthstrat_final_cta_primary {
        padding-left: 22px;
      }
      @media (max-width: 767px) {
        .cs_healthstrat_service_cta_actions {
          justify-self: stretch;
          align-items: stretch;
          min-width: 0;
          transform: none;
        }
        .cs_healthstrat_service_cta_actions .cs_healthstrat_final_cta_whatsapp {
          width: 100%;
        }
      }
    </style>`;

const expertiseCtaButtonStyles = `    <style id="healthstrat-expertise-cta-buttons">
      .cs_cta.cs_style_3.cs_expertise_cta::before {
        background: linear-gradient(90deg, rgba(0, 59, 113, 0.68) 0%, rgba(0, 80, 144, 0.42) 48%, rgba(0, 80, 144, 0.08) 72%, rgba(0, 80, 144, 0) 100%);
      }
      .cs_healthstrat_expertise_cta_actions {
        justify-content: flex-start;
        align-items: center;
        flex-wrap: nowrap;
        gap: 16px;
        margin-top: 28px;
      }
      .cs_healthstrat_expertise_cta_btn {
        min-height: 56px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
        border-radius: 999px;
        padding: 0 24px;
        font-size: 23px;
        font-weight: 700;
        line-height: 1.2;
        white-space: nowrap;
        box-shadow: none;
      }
      .cs_healthstrat_expertise_cta_btn:hover {
        transform: translateY(-2px);
      }
      .cs_healthstrat_expertise_cta_primary {
        min-width: 320px;
        background: #fff;
        color: #003b71;
        box-shadow: 0 10px 24px rgba(0, 0, 0, 0.18);
      }
      .cs_healthstrat_expertise_cta_primary:hover {
        background: #f7fbff;
        color: #003b71;
      }
      .cs_healthstrat_expertise_cta_secondary {
        min-width: 190px;
        background: #2f9f44;
        color: #fff;
      }
      .cs_healthstrat_expertise_cta_secondary:hover {
        background: #238936;
        color: #fff;
      }
      .cs_healthstrat_expertise_cta_arrow {
        color: #60a030;
        font-size: 16px;
        line-height: 1;
      }
      .cs_healthstrat_expertise_cta_icon {
        font-size: 24px;
        line-height: 1;
      }
      @media (max-width: 575px) {
        .cs_healthstrat_expertise_cta_actions {
          flex-direction: column;
          align-items: stretch;
          flex-wrap: nowrap;
          gap: 12px;
          margin-top: 24px;
        }
        .cs_healthstrat_expertise_cta_btn {
          width: 100%;
          min-width: 0;
          min-height: 60px;
          font-size: 25px;
        }
      }
    </style>`;

let html = fs.readFileSync(pagePath, 'utf-8');

html = html
  .replaceAll('href="assets/', 'href="/assets/')
  .replaceAll('src="assets/', 'src="/assets/')
  .replaceAll('data-src="assets/', 'data-src="/assets/');

html = html.replace(/<title>.*?<\/title>/i, `<title>${meta.title}</title>`);

const metaTags = `
    <meta name="description" content="${meta.description}">
    <link rel="canonical" href="${canonicalUrl}">
    <meta property="og:type" content="website">
    <meta property="og:title" content="${meta.title}">
    <meta property="og:description" content="${meta.description}">
    <meta property="og:url" content="${canonicalUrl}">
    <meta property="og:image" content="${siteUrl}/assets/img/healthstrat/generated/global-hero-healthcare-transformation.webp">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="${meta.title}">
    <meta name="twitter:description" content="${meta.description}">`;

if (!html.includes('name="description"')) {
  html = html.replace('</head>', `${metaTags}\n  </head>`);
}

if (file === 'index.html') {
  html = html.replace(
    /<h1([^>]*class="[^"]*cs_section_subtitle[^"]*"[^>]*)>(.*?)<\/h1>/gs,
    '<p$1>$2</p>',
  );
}

html = html.replace(/<\/header>/i, '</header><main id="main-content">');
html = html.replace(/<footer\b/i, '</main><footer');
html = html.replace(/<button class="cs_header_submit_btn">/g, '<button class="cs_header_submit_btn" aria-label="Search">');
html = html.replace(/aria-label="WhatsApp HealthStrat"/g, 'aria-label="WhatsApp Us"');

if (ctaButtonPages.has(file)) {
  const ctaButtons = serviceCtaButtonPages.has(file)
    ? sharedCtaButtons.replace(
        'class="cs_healthstrat_cta_actions"',
        'class="cs_healthstrat_cta_actions cs_healthstrat_service_cta_actions"',
      )
    : expertiseCtaButtonPages.has(file)
      ? expertiseCtaButtons
    : sharedCtaButtons;

  html = html.replace(
    /<div class="(?:cs_about_partner_actions|cs_cta_actions|cs_service_final_cta_actions|cs_nursing_final_cta_actions)">[\s\S]*?<\/div>(?=\s*<\/(?:div|section)>)/,
    ctaButtons,
  );

  if (!html.includes('id="healthstrat-shared-cta-buttons"')) {
    html = html.replace('</head>', `${sharedCtaButtonStyles}\n  </head>`);
  }

  if (serviceCtaButtonPages.has(file) && !html.includes('id="healthstrat-service-cta-buttons"')) {
    html = html.replace('</head>', `${serviceCtaButtonStyles}\n  </head>`);
  }

  if (expertiseCtaButtonPages.has(file) && !html.includes('id="healthstrat-expertise-cta-buttons"')) {
    html = html.replace('</head>', `${expertiseCtaButtonStyles}\n  </head>`);
  }
}

const readMoreLabels = {
  'health-care-strategy-transformation.html': 'healthcare strategy and transformation',
  'clinical-governance-quality.html': 'clinical governance and quality',
  'nursing-workforce-development.html': 'nursing and workforce development',
  'innovation-design-thinking.html': 'innovation and design thinking',
  'education-training.html': 'education and training',
};

for (const [href, label] of Object.entries(readMoreLabels)) {
  html = html.replace(
    new RegExp(`(<a[^>]+href="${href}"[^>]*>\\s*<span class="cs_image_box_btn_text">)Read More(</span>)`, 'g'),
    `$1Read More<span class="visually-hidden"> about ${label}</span>$2`,
  );
}

html = html.replace(
  /\s*<div class="[^"]*\bcs_preloader\b[^"]*">\s*<div class="cs_preloader_in">.*?<\/div>\s*<\/div>/s,
  '',
);

html = html.replace(/<img\b([^>]*)>/gi, (match, attrs) => {
  const srcMatch = attrs.match(/\bsrc="([^"]+)"/i);
  if (!srcMatch) return match;

  const originalSrc = srcMatch[1];
  const image = imageManifest[originalSrc];
  let nextAttrs = attrs;

  if (image?.optimized) {
    nextAttrs = nextAttrs.replace(/\bsrc="[^"]+"/i, `src="${image.optimized}"`);
  }

  if (image?.width && !/\bwidth="/i.test(nextAttrs)) {
    nextAttrs += ` width="${image.width}"`;
  }

  if (image?.height && !/\bheight="/i.test(nextAttrs)) {
    nextAttrs += ` height="${image.height}"`;
  }

  if (!/\bdecoding="/i.test(nextAttrs)) {
    nextAttrs += ' decoding="async"';
  }

  const isPriorityImage =
    originalSrc.includes('healthstrat_logo') ||
    originalSrc.includes('healthstrat_preloader_logo') ||
    originalSrc.includes('global-case-study-expansion');

  if (!isPriorityImage && !/\bloading="/i.test(nextAttrs)) {
    nextAttrs += ' loading="lazy"';
  }

  if (isPriorityImage && !/\bfetchpriority="/i.test(nextAttrs)) {
    nextAttrs += ' fetchpriority="high"';
  }

  return `<img${nextAttrs}>`;
});

html = html.replace(/\bdata-src="([^"]+)"/gi, (match, originalSrc) => {
  const image = imageManifest[originalSrc];
  return image?.optimized ? `data-src="${image.optimized}"` : match;
});

html = html.replace(/^\s*<script[^>]+\/assets\/js\/\.min\.js[^>]*><\/script>\s*$/gim, '');

const optionalAssets = [
  {
    used: /\bwow\b|\bdata-wow-|(?:^|\s)(?:fadeIn(?:Up|Down|Left|Right)?|zoomIn|slideIn(?:Up|Down|Left|Right)?)(?:\s|")/i,
    patterns: [
      /^\s*<link[^>]+\/assets\/css\/animate\.css[^>]*>\s*$/gim,
      /^\s*<script[^>]+\/assets\/js\/wow\.min\.js[^>]*><\/script>\s*$/gim,
    ],
  },
  {
    used: /\bclass="[^"]*\bplayer\b/i,
    patterns: [/^\s*<script[^>]+\/assets\/js\/YTPlayer\.min\.js[^>]*><\/script>\s*$/gim],
  },
  {
    used: /\bcs_ripple_activate\b/i,
    patterns: [/^\s*<script[^>]+\/assets\/js\/ripples\.min\.js[^>]*><\/script>\s*$/gim],
  },
  {
    used: /\bclass="[^"]*\bodometer\b/i,
    patterns: [
      /^\s*<link[^>]+\/assets\/css\/odometer\.css[^>]*>\s*$/gim,
      /^\s*<script[^>]+\/assets\/js\/odometer\.js[^>]*><\/script>\s*$/gim,
    ],
  },
  {
    used: /\bcs_slider\b/i,
    patterns: [
      /^\s*<link[^>]+\/assets\/css\/slick\.min\.css[^>]*>\s*$/gim,
      /^\s*<script[^>]+\/assets\/js\/jquery\.slick\.min\.js[^>]*><\/script>\s*$/gim,
    ],
  },
  {
    used: /\bcs_fullscreen_|\bcs_parallax_slider\b/i,
    patterns: [
      /^\s*<link[^>]+\/assets\/css\/swiper\.min\.css[^>]*>\s*$/gim,
      /^\s*<script[^>]+\/assets\/js\/swiper\.min\.js[^>]*><\/script>\s*$/gim,
    ],
  },
];

for (const asset of optionalAssets) {
  if (!asset.used.test(html)) {
    for (const pattern of asset.patterns) {
      html = html.replace(pattern, '');
    }
  }
}

const asyncStyles = new Set([
  '/assets/css/bootstrap.min.css',
  '/assets/css/fontawesome.min.css',
  '/assets/css/slick.min.css',
]);

html = html.replace(/<link([^>]+)rel="stylesheet"([^>]+)href="([^"]+)"([^>]*)>/gi, (match, before, between, href, after) => {
  if (!asyncStyles.has(href)) return match;
  return `<link${before}rel="preload"${between}href="${href}"${after} as="style" onload="this.onload=null;this.rel='stylesheet'"><noscript>${match}</noscript>`;
});

html = html.replace(/(<script\b(?![^>]*\bdefer\b)[^>]*\bsrc="[^"]+"[^>]*)><\/script>/gi, '$1 defer></script>');
--- 

<Fragment set:html={html} />
